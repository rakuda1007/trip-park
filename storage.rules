rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // 掲示板本文に貼り付けた画像（グループメンバーが閲覧する想定。書き込みはアップロードしたユーザー本人のみ）
    match /groups/{groupId}/bulletin_images/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // 旅行の思い出写真（一覧サムネイルに利用）
    match /groups/{groupId}/memory_photos/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
