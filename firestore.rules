rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function groupOwnerId(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId;
    }

    function isGroupMember(groupId) {
      return exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    function memberRole(groupId) {
      return exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid))
        ? get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role
        : null;
    }

    function isOwnerOrAdmin(groupId) {
      return groupOwnerId(groupId) == request.auth.uid ||
        memberRole(groupId) == 'admin' ||
        memberRole(groupId) == 'owner';
    }

    function sharingLabelValid(data) {
      return data.label is string &&
        data.label.size() > 0 &&
        data.label.size() <= 200 &&
        data.sortOrder is int &&
        (data.memo is string || data.memo == null);
    }

    function sharingItemCoreKeys(data) {
      return data.keys().hasAll([
        'label', 'memo', 'sortOrder',
        'createdByUserId', 'createdByDisplayName', 'createdAt', 'updatedAt'
      ]);
    }

    function sharingAssignmentNew(data) {
      return data.keys().hasAll(['assignedFamilyId', 'assignedFamilyName']);
    }

    function sharingAssignmentLegacy(data) {
      return data.keys().hasAll(['assignedUserId', 'assignedDisplayName']);
    }

    function sharingAssignmentOk(data) {
      return (sharingAssignmentNew(data) && !sharingAssignmentLegacy(data)) ||
        (sharingAssignmentLegacy(data) && !sharingAssignmentNew(data));
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /groups/{groupId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId &&
          exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
        allow update: if request.auth != null && request.auth.uid == userId;
      }

      match /households/{householdId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /inviteCodes/{code} {
      allow read: if true;
      allow create: if request.auth != null &&
        exists(/databases/$(database)/documents/groups/$(request.resource.data.groupId)) &&
        get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.ownerId == request.auth.uid;
      allow delete: if request.auth != null;
      allow update: if false;
    }

    match /groups/{groupId} {
      allow read: if request.auth != null && isGroupMember(groupId);
      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.keys().hasAll(['name', 'ownerId', 'inviteCode', 'createdAt', 'updatedAt']) &&
        request.resource.data.keys().hasOnly([
          'name', 'description', 'ownerId', 'inviteCode',
          'createdAt', 'updatedAt', 'tripStartDate', 'tripEndDate',
          'destination', 'status'
        ]);
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        (memberRole(groupId) == 'admin' &&
          request.resource.data.ownerId == resource.data.ownerId &&
          request.resource.data.inviteCode == resource.data.inviteCode &&
          request.resource.data.name == resource.data.name)
      );
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;

      match /members/{userId} {
        allow read: if request.auth != null && (
          isGroupMember(groupId) || request.auth.uid == userId
        );

        allow create: if request.auth != null && request.auth.uid == userId && (
          (request.resource.data.role == 'owner' &&
            groupOwnerId(groupId) == request.auth.uid) ||
          (request.resource.data.role == 'member' &&
            request.resource.data.keys().hasAll(['role', 'joinedAt', 'code']) &&
            get(/databases/$(database)/documents/inviteCodes/$(request.resource.data.code)).data.groupId == groupId)
        );

        allow update: if request.auth != null && request.auth.uid == userId &&
          request.resource.data.role == resource.data.role &&
          !request.resource.data.keys().hasAny(['code']);

        allow delete: if request.auth != null && (
          request.auth.uid == userId ||
          groupOwnerId(groupId) == request.auth.uid
        );
      }

      match /bulletinPosts/{postId} {
        allow read: if request.auth != null && isGroupMember(groupId);
        allow create: if request.auth != null && isGroupMember(groupId) &&
          request.resource.data.authorUserId == request.auth.uid &&
          request.resource.data.pinned == false &&
          request.resource.data.keys().hasAll([
            'title', 'body', 'authorUserId', 'authorDisplayName',
            'category', 'importance', 'pinned', 'createdAt', 'updatedAt'
          ]);
        allow update: if request.auth != null && isGroupMember(groupId) && (
          isOwnerOrAdmin(groupId) ||
          (
            request.auth.uid == resource.data.authorUserId &&
            request.resource.data.authorUserId == resource.data.authorUserId &&
            request.resource.data.pinned == resource.data.pinned
          )
        );
        allow delete: if request.auth != null && isGroupMember(groupId) && (
          isOwnerOrAdmin(groupId) || resource.data.authorUserId == request.auth.uid
        );

        match /replies/{replyId} {
          allow read: if request.auth != null && isGroupMember(groupId);
          allow create: if request.auth != null && isGroupMember(groupId) &&
            request.resource.data.authorUserId == request.auth.uid &&
            request.resource.data.keys().hasAll([
              'body', 'authorUserId', 'authorDisplayName', 'createdAt', 'updatedAt'
            ]);
          allow update: if request.auth != null && isGroupMember(groupId) && (
            isOwnerOrAdmin(groupId) ||
            (
              request.auth.uid == resource.data.authorUserId &&
              request.resource.data.authorUserId == resource.data.authorUserId
            )
          );
          allow delete: if request.auth != null && isGroupMember(groupId) && (
            isOwnerOrAdmin(groupId) || resource.data.authorUserId == request.auth.uid
          );
        }

        match /replyReadProgress/{readerUid} {
          allow read: if request.auth != null && isGroupMember(groupId);
          allow create, update: if request.auth != null && isGroupMember(groupId) &&
            request.auth.uid == readerUid &&
            request.resource.data.keys().hasOnly(['lastReadReplyId', 'updatedAt']) &&
            (request.resource.data.lastReadReplyId == null || request.resource.data.lastReadReplyId is string);
          allow delete: if false;
        }
      }

      match /scheduleCandidates/{candidateId} {
        allow read: if request.auth != null && isGroupMember(groupId);
        allow create: if request.auth != null && isOwnerOrAdmin(groupId) &&
          request.resource.data.keys().hasAll(['date', 'startDate', 'endDate', 'createdAt', 'createdBy']);
        allow delete: if request.auth != null && isOwnerOrAdmin(groupId);
        allow update: if false;
      }

      match /scheduleResponses/{responseId} {
        allow read: if request.auth != null && isGroupMember(groupId);
        allow create, update: if request.auth != null && isGroupMember(groupId) &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.keys().hasAll(['userId', 'candidateId', 'answer', 'updatedAt']);
        allow delete: if request.auth != null && isGroupMember(groupId) && (
          resource.data.userId == request.auth.uid ||
          isOwnerOrAdmin(groupId)
        );
      }

      match /config/{docId} {
        allow read: if request.auth != null && isGroupMember(groupId);
        allow create, update: if request.auth != null && isOwnerOrAdmin(groupId);
        allow delete: if request.auth != null && isOwnerOrAdmin(groupId);
      }

      match /tripRoutes/{routeId} {
        allow read: if request.auth != null && isGroupMember(groupId);
        allow create: if request.auth != null && isGroupMember(groupId) &&
          request.resource.data.createdByUserId == request.auth.uid &&
          request.resource.data.waypoints is list &&
          request.resource.data.keys().hasAll([
            'dayNumber', 'departurePoint', 'departureMapUrl',
            'destinationName', 'destinationMapUrl',
            'waypoints', 'routeMapUrl', 'memo', 'isDone',
            'sortOrder', 'routeLabel', 'title', 'destinationAddress', 'destinationMemo',
            'createdByUserId', 'createdByDisplayName', 'createdAt', 'updatedAt'
          ]);
        allow update: if request.auth != null && isGroupMember(groupId) &&
          request.resource.data.createdByUserId == resource.data.createdByUserId &&
          request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if request.auth != null && isGroupMember(groupId) && (
          isOwnerOrAdmin(groupId) || resource.data.createdByUserId == request.auth.uid
        );
      }

      match /expenses/{expenseId} {
        allow read: if request.auth != null && isGroupMember(groupId);
        allow create: if request.auth != null && isGroupMember(groupId) &&
          request.resource.data.createdByUserId == request.auth.uid &&
          request.resource.data.splitMode in ['equal', 'weighted'] &&
          request.resource.data.weightByFamilyId is map &&
          request.resource.data.weightByFamilyId.size() >= 1 &&
          request.resource.data.amount is int &&
          request.resource.data.amount >= 1 &&
          request.resource.data.participantFamilyIds is list &&
          request.resource.data.participantFamilyIds.size() >= 1 &&
          exists(/databases/$(database)/documents/groups/$(groupId)/families/$(request.resource.data.paidByFamilyId)) &&
          request.resource.data.participantFamilyIds.hasAll([request.resource.data.paidByFamilyId]) &&
          request.resource.data.category in ['food', 'transport', 'lodging', 'other'] &&
          request.resource.data.keys().hasAll([
            'amount', 'paidByFamilyId', 'expenseDate', 'category', 'memo', 'splitMode',
            'participantFamilyIds', 'weightByFamilyId', 'participantUserIds',
            'createdByUserId', 'createdAt', 'updatedAt'
          ]);
        allow update: if request.auth != null && isGroupMember(groupId) &&
          request.resource.data.createdByUserId == resource.data.createdByUserId &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.splitMode in ['equal', 'weighted'] &&
          request.resource.data.weightByFamilyId is map &&
          request.resource.data.weightByFamilyId.size() >= 1 &&
          request.resource.data.amount is int &&
          request.resource.data.amount >= 1 &&
          request.resource.data.participantFamilyIds is list &&
          request.resource.data.participantFamilyIds.size() >= 1 &&
          exists(/databases/$(database)/documents/groups/$(groupId)/families/$(request.resource.data.paidByFamilyId)) &&
          request.resource.data.participantFamilyIds.hasAll([request.resource.data.paidByFamilyId]) &&
          request.resource.data.category in ['food', 'transport', 'lodging', 'other'] &&
          (isOwnerOrAdmin(groupId) || resource.data.createdByUserId == request.auth.uid) &&
          request.resource.data.keys().hasAll([
            'amount', 'paidByFamilyId', 'expenseDate', 'category', 'memo', 'splitMode',
            'participantFamilyIds', 'weightByFamilyId', 'participantUserIds',
            'createdByUserId', 'createdAt', 'updatedAt'
          ]);
        allow delete: if request.auth != null && isGroupMember(groupId) && (
          isOwnerOrAdmin(groupId) || resource.data.createdByUserId == request.auth.uid
        );
      }

      match /families/{familyId} {
        allow read: if request.auth != null && isGroupMember(groupId);
        allow create: if request.auth != null && isGroupMember(groupId) &&
          request.resource.data.createdByUserId == request.auth.uid &&
          request.resource.data.memberUserIds is list &&
          request.resource.data.adultCount is int &&
          request.resource.data.childCount is int &&
          request.resource.data.adultCount >= 0 &&
          request.resource.data.childCount >= 0 &&
          (request.resource.data.childRatio is float || request.resource.data.childRatio is int) &&
          request.resource.data.childRatio > 0 &&
          request.resource.data.childRatio <= 1 &&
          request.resource.data.keys().hasAll([
            'name', 'adultCount', 'childCount', 'childRatio', 'memberUserIds',
            'createdByUserId', 'createdAt', 'updatedAt'
          ]);
        allow update: if request.auth != null && isGroupMember(groupId) &&
          request.resource.data.createdByUserId == resource.data.createdByUserId &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.memberUserIds is list &&
          request.resource.data.adultCount is int &&
          request.resource.data.childCount is int &&
          request.resource.data.adultCount >= 0 &&
          request.resource.data.childCount >= 0 &&
          (request.resource.data.childRatio is float || request.resource.data.childRatio is int) &&
          request.resource.data.childRatio > 0 &&
          request.resource.data.childRatio <= 1 &&
          (isOwnerOrAdmin(groupId) || resource.data.createdByUserId == request.auth.uid) &&
          request.resource.data.keys().hasAll([
            'name', 'adultCount', 'childCount', 'childRatio', 'memberUserIds',
            'createdByUserId', 'createdAt', 'updatedAt'
          ]);
        allow delete: if request.auth != null && isGroupMember(groupId) && (
          isOwnerOrAdmin(groupId) || resource.data.createdByUserId == request.auth.uid
        );
      }

      match /destinationCandidates/{candidateId} {
        allow read: if request.auth != null && isGroupMember(groupId);
        allow create: if request.auth != null && isGroupMember(groupId) &&
          request.resource.data.proposedByUserId == request.auth.uid;
        allow delete: if request.auth != null && (
          isOwnerOrAdmin(groupId) ||
          resource.data.proposedByUserId == request.auth.uid
        );
        allow update: if request.auth != null && isGroupMember(groupId) && (
          isOwnerOrAdmin(groupId) ||
          resource.data.proposedByUserId == request.auth.uid
        );
      }

      match /destinationVotes/{voteId} {
        allow read: if request.auth != null && isGroupMember(groupId);
        // create/update: 書き込み内容の userId が本人。setDoc の上書きは update。
        allow create: if request.auth != null && isGroupMember(groupId) &&
          request.resource.data.userId == request.auth.uid;
        allow update: if request.auth != null && isGroupMember(groupId) &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == request.auth.uid;
        // delete: 削除後の request.resource では userId を検証できないため resource を使う
        allow delete: if request.auth != null && isGroupMember(groupId) &&
          resource.data.userId == request.auth.uid;
      }

      match /sharingItems/{itemId} {
        allow read: if request.auth != null && isGroupMember(groupId);
        allow create: if request.auth != null && isGroupMember(groupId) &&
          request.resource.data.createdByUserId == request.auth.uid &&
          sharingItemCoreKeys(request.resource.data) &&
          sharingAssignmentOk(request.resource.data) &&
          sharingAssignmentNew(request.resource.data) &&
          sharingLabelValid(request.resource.data) &&
          (request.resource.data.assignedFamilyId == null ||
            request.resource.data.assignedFamilyId is string) &&
          (request.resource.data.assignedFamilyName == null ||
            request.resource.data.assignedFamilyName is string);
        allow update: if request.auth != null && isGroupMember(groupId) &&
          request.resource.data.createdByUserId == resource.data.createdByUserId &&
          request.resource.data.createdAt == resource.data.createdAt &&
          sharingItemCoreKeys(request.resource.data) &&
          sharingAssignmentOk(request.resource.data) &&
          sharingLabelValid(request.resource.data) &&
          (request.resource.data.assignedFamilyId == null ||
            request.resource.data.assignedFamilyId is string) &&
          (request.resource.data.assignedFamilyName == null ||
            request.resource.data.assignedFamilyName is string) &&
          (request.resource.data.assignedUserId == null ||
            request.resource.data.assignedUserId is string) &&
          (request.resource.data.assignedDisplayName == null ||
            request.resource.data.assignedDisplayName is string);
        allow delete: if request.auth != null && isGroupMember(groupId) && (
          resource.data.createdByUserId == request.auth.uid ||
          isOwnerOrAdmin(groupId)
        );
      }
    }

    match /circles/{circleId} {
      allow read: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;

      match /members/{memberId} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/circles/$(circleId)).data.ownerId == request.auth.uid;
      }
    }
  }
}
